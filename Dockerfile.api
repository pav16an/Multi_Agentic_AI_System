FROM python:3.11-slim

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

# Copy requirements and install Python packages
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# --- THE MAGIC FIX: PRE-DOWNLOAD THE ML MODEL ---
# This forces Docker to download the model during the build phase.
# Now, Uvicorn will start instantly without causing Render to time out!
RUN python -c "from sentence_transformers import SentenceTransformer; SentenceTransformer('all-MiniLM-L6-v2')"

# Copy the rest of your application code
COPY . .

# Start Uvicorn, dynamically binding to Render's required PORT
CMD sh -c "uvicorn api:app --host 0.0.0.0 --port ${PORT:-10000}"
